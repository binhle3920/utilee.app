{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "utilee",
  "title": "Utilee",
  "description": "Quick access to Utilee developer tools",
  "icon": "icon.png",
  "author": "utilee",
  "categories": ["Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "search-tools",
      "title": "Search Tools",
      "description": "Search and open Utilee developer tools",
      "mode": "view",
      "keywords": ["utilee", "tools", "developer", "utility"]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.3",
    "@raycast/utils": "^1.19.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.14",
    "@types/react": "19.0.12",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  }
}
